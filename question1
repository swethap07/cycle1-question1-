#include <stdio.h>
#include <math.h>
#define PI 3.14  

float diameter(float x1, float y1, float x2, float y2)
{
    float D;
    D = sqrt((x2 - x1)(x2 - x1) + (y2 - y1)(y2 - y1));
    return D;
}
float area(float D)
{
    float r;
    r = D / 2;
    return PI * r * r;
}
float perimeter(float D)
{
    float r;
    r = D / 2;
    return 2 * PI * r;
}
int main()
{
    float x1, y1, x2, y2;
    float D, A, P;

    printf("Enter x1 y1: ");
    scanf("%f %f", &x1, &y1);
    printf("Enter x2 y2: ");
    scanf("%f %f", &x2, &y2);
    D = diameter(x1, y1, x2, y2);
    A = area(D);
    P = perimeter(D);
    printf("Diameter is %.2f\n", D);
    printf("Area is %.2f\n", A);
    printf("Perimeter is  %.2f\n", P);
    return 0;
}
